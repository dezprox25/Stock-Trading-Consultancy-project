PORT=5002

MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/stock_dashboard?retryWrites=true&w=majority

REDIS_URL=redis://127.0.0.1:6379

JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Set to "production" and provide CLIENT_API_URL to connect to real broker feed
NODE_ENV=development
CLIENT_API_URL=wss://your-broker-websocket-url

RESEND_API_KEY=your_resend_api_key_here

# Module 1 (Market Data API) credentials
MOD1_API_KEY=your_mod1_api_key_here
MOD1_API_SECRET=your_mod1_api_secret_here

# Module 2 (Interactive Data API) credentials
MOD2_API_KEY=your_mod2_api_key_here
MOD2_API_SECRET=your_mod2_api_secret_here
