PORT=5001

MONGODB_URI=mongodb://127.0.0.1:27017/stock_dashboard
REDIS_URL=redis://127.0.0.1:6379

JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Zebu MYNT / Zebu Trade market data feed.
# CLIENT_API_URL is kept for compatibility; ZEBU_WS_URL takes precedence when set.
NODE_ENV=development
CLIENT_API_URL=wss://your-zebu-mynt-websocket-url
ZEBU_WS_URL=wss://your-zebu-mynt-websocket-url

RESEND_API_KEY=your_resend_api_key_here

MOD1_API_KEY=your_mod1_market_data_api_key_here
MOD1_API_SECRET=your_mod1_market_data_api_secret_here

# Required for Zebu MYNT live Module1 OI.
# Use backend .env only. Never expose these values to frontend code.
ZEBU_CLIENT_ID=your_zebu_client_id_here
ZEBU_USER_ID=your_zebu_user_id_here
ZEBU_ACCOUNT_ID=your_zebu_account_id_here
ZEBU_SUSERTOKEN=your_zebu_daily_session_token_here
ZEBU_SOURCE=API
ZEBU_REDIRECT_URL=http://localhost:5002/api/module1/zebu/oauth/callback
ZEBU_OAUTH_AUTHORIZE_URL=https://your-zebu-oauth-authorize-url
ZEBU_OAUTH_TOKEN_URL=https://your-zebu-oauth-token-url
ZEBU_AUTH_CODE=optional_manual_callback_code

# Format: EXCHANGE|TOKEN:LOCAL_SYMBOL
# Example: NFO|123456:NIFTY-FUT
ZEBU_NIFTY_FUT_TOKEN=NFO|your_futures_token:NIFTY-FUT
ZEBU_NIFTY_CE_TOKENS=NFO|your_call_token_1:NIFTY22500CE,NFO|your_call_token_2:NIFTY22550CE
ZEBU_NIFTY_PE_TOKENS=NFO|your_put_token_1:NIFTY22500PE,NFO|your_put_token_2:NIFTY22550PE

# Module 2 (Interactive Data API) credentials
MOD2_API_KEY=your_mod2_api_key_here
MOD2_API_SECRET=your_mod2_api_secret_here
AETRAM_INTERACTIVE_API_BASE_URL=https://your-aetram-interactive-api-base-url
AETRAM_INTERACTIVE_AUTH_URL=https://your-aetram-interactive-auth-url
